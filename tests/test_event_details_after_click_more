import unittest
from selenium import webdriver
from selenium.webdriver.common.by import By
from selenium.webdriver.support.ui import WebDriverWait
from selenium.webdriver.support import expected_conditions as EC


class TestEventDetails(unittest.TestCase):

    def setUp(self):
        self.driver = webdriver.Chrome()
        self.driver.maximize_window()
        self.wait = WebDriverWait(self.driver, 15)
        self.driver.get("https://www.greencity.cx.ua/#/greenCity/events")

    def test_event_details_after_click_more(self):
        driver = self.driver
        wait = self.wait

        wait.until(EC.presence_of_element_located((By.TAG_NAME, "body")))

        event_cards = wait.until(
            EC.presence_of_all_elements_located((By.XPATH, "//mat-card"))
        )

        for i in range(min(5, len(event_cards))):

            
            event_cards = driver.find_elements(By.XPATH, "//mat-card")
            card = event_cards[i]

            title_element = card.find_element(By.XPATH, ".//p[contains(@class ,'event-name')]")
            event_title = title_element.text.strip()

            more_button = card.find_element(
                By.XPATH,
                ".//button[contains(text(),'Більше') or contains(text(),'More')]"
            )

            driver.execute_script("arguments[0].click();", more_button)

            wait.until(
                EC.presence_of_element_located((By.XPATH, "//app-event-details"))
            )

            details_text = driver.find_element(By.TAG_NAME, "body").text

            self.assertTrue(
                event_title in details_text,
                f" Подія '{event_title}' не відповідає деталям"
            )

            driver.back()

            wait.until(
                EC.presence_of_all_elements_located((By.XPATH, "//mat-card"))
            )

    def tearDown(self):
        self.driver.quit()


if __name__ == "__main__":
    unittest.main()
